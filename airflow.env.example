# Airflow Environment Configuration (Template)
# Copy this to airflow.env and fill in the secrets.
# Generate keys with: make fernet-key && make webserver-key && make jwt-secret-key

# ──────────────────────────────────────────────────────
# Airflow Core
# ──────────────────────────────────────────────────────
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your_generated_fernet_key_here

# ──────────────────────────────────────────────────────
# Web/API server base URL
# In 2.x this lived under [webserver].base_url. In 3.x it moved to
# [api].base_url — the old key still resolves but emits a DeprecationWarning.
# ──────────────────────────────────────────────────────
AIRFLOW__API__BASE_URL=http://localhost:8080

# ──────────────────────────────────────────────────────
# API server signing key (Airflow 3.x)
# In 2.x this lived under [webserver].secret_key. In 3.x the config moved
# to [api].secret_key — using the old key still works but emits a
# DeprecationWarning at every startup.
# ──────────────────────────────────────────────────────
AIRFLOW__API__SECRET_KEY=your_generated_secret_key_here

# ──────────────────────────────────────────────────────
# API Auth (Execution API)
# ──────────────────────────────────────────────────────
# Synchronize this secret across all Airflow containers for token verification.
AIRFLOW__API_AUTH__JWT_SECRET=your_generated_jwt_secret_key_here

# ──────────────────────────────────────────────────────
# OpenLineage (P3.6)
# ──────────────────────────────────────────────────────
# The OpenLineage Airflow provider emits a lineage event per task instance.
# When OPENLINEAGE_URL is empty, the provider only logs events — nothing
# leaves the container. Set OPENLINEAGE_URL=http://marquez:5000 (or any
# OpenLineage-compatible collector) to ship them.
#
# OPENLINEAGE_NAMESPACE groups events from this project together across
# multiple pipelines / clusters in the collector.
OPENLINEAGE_URL=
OPENLINEAGE_NAMESPACE=data_lake
AIRFLOW__OPENLINEAGE__NAMESPACE=data_lake
# Transport is empty when OPENLINEAGE_URL is empty (disabled).
# When you set OPENLINEAGE_URL, the Airflow provider auto-detects it.
