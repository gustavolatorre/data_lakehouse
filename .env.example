# ──────────────────────────────────────────────────────
# Airflow
# ──────────────────────────────────────────────────────
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=<change-me-min-24-chars>
AIRFLOW_EMAIL=admin@example.com

# ──────────────────────────────────────────────────────
# MinIO (S3-compatible object storage)
# ──────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=<change-me-min-24-chars>
# Set to true in staging/prod when MinIO/S3 is fronted by HTTPS.
MINIO_SECURE=false
# Data-plane service account (recommended, F2-1). Spark / Dremio / the app
# authenticate with this scoped account (RW on staging + warehouse only) instead
# of root, so a compromised job can't administer MinIO; minio-setup creates it on
# startup. Set a strong secret below. (Removing both lines falls back to root.)
MINIO_SVC_ACCESS_KEY=lakehouse-app
MINIO_SVC_SECRET_KEY=<change-me-min-24-chars>

# ──────────────────────────────────────────────────────
# PostgreSQL (Airflow metadata)
# ──────────────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=<change-me-min-24-chars>

# ──────────────────────────────────────────────────────
# Nessie (Iceberg REST Catalog)
# ──────────────────────────────────────────────────────
NESSIE_URI=http://nessie:19120/api/v2

# ──────────────────────────────────────────────────────
# Dremio (Query Engine)
# ──────────────────────────────────────────────────────
DREMIO_ADMIN_USER=dremio_admin
DREMIO_ADMIN_PASSWORD=<change-me-min-24-chars>
# Host of the Dremio coordinator. Pinned to 'dremio' in docker local network.
DREMIO_HOST=dremio
DREMIO_PORT=9047
# Set to true in real production when SSL is enabled on Dremio.
DREMIO_USE_SSL=false

# ──────────────────────────────────────────────────────
# Alerting (optional, opt-in)
# ──────────────────────────────────────────────────────
# Slack incoming webhook for DAG-failure and quarantine alerts. Leave empty to
# keep alerts log-only (the default). Same opt-in pattern as OPENLINEAGE_URL.
ALERT_WEBHOOK_URL=

# ──────────────────────────────────────────────────────
# Brasileirão (GE / Globo Esporte) source — current-season auto-derivation
# ──────────────────────────────────────────────────────
# The active edition is derived automatically from the run's year: the GE
# championship UUID is stable and only the per-year phase slug changes, so the
# pipeline rolls over to the next season with NO config edit. GE_SEASONS is an
# optional override (CSV of years) to pin/force specific edition(s); leave empty
# for automatic current-season. (The GE public API only serves the active
# season — past years are not retrievable through it.)
#GE_SEASONS=2026
